# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# /setup fills this in automatically.

# ── AWS credentials ───────────────────────────────────────────────────────────
# Create an IAM user with AdministratorAccess, generate an access key.
# After setup, CI uses OIDC (no keys needed there).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=    # only needed for temporary/STS credentials

# ── AWS region ────────────────────────────────────────────────────────────────
# Must match infra/pulumi-ingress/Pulumi.prod.yaml and infra/pulumi/Pulumi.prod.yaml
AWS_DEFAULT_REGION=us-east-1

# ── Pulumi Cloud ──────────────────────────────────────────────────────────────
# Get this from: https://app.pulumi.com → Avatar → Access Tokens
PULUMI_ACCESS_TOKEN=

# ── Optional: override Pulumi stack outputs (avoids an extra API call on deploy)
# Run 'make infra-outputs' after deploying to get these values.
# SITE_BUCKET=
# CF_DISTRIBUTION_ID=

# ── Optional: for AI-generated hero images ────────────────────────────────────
# OPENAI_API_KEY=

# ── Optional: for gh Docker service ──────────────────────────────────────────
# GH_TOKEN=    # from: gh auth token
