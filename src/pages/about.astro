---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About — AUTHOR_NAME"
  description="About AUTHOR_NAME."
>
  <div class="container page">

    <header class="page-header">
      <img src="/avatar.jpg" alt="AUTHOR_NAME" class="avatar" />
      <h1 class="page-title">AUTHOR_NAME</h1>
    </header>

    <div class="prose about-prose">

      <p>
        Edit this page at <code>src/pages/about.astro</code> to tell your story.
      </p>

      <p>
        What do you do? What have you built? What do you care about?
        This is the place to give readers a sense of who you are.
      </p>

      <p>This is where I write things down to figure out what I think.</p>

    </div>

    <div class="links">
      <a href="/blog">Writing</a>
      <span aria-hidden="true">·</span>
      <a href="/#projects">Projects</a>
    </div>

  </div>
</Layout>

<style>
  .page {
    padding-top: 4rem;
    padding-bottom: 5rem;
    max-width: 580px;
  }

  .page-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border-light);
  }

  .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
    border: 2px solid var(--border-light);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .about-prose p {
    margin-bottom: 1.4rem;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .about-prose p:last-child { margin-bottom: 0; }

  .links {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-light);
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--muted);
    display: flex;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .links a { color: var(--muted); text-decoration: none; }
  .links a:hover { color: var(--link); }
</style>
